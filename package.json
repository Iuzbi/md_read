{
  "name": "md-read",
  "version": "2.0.1",
  "description": "A desktop Markdown reader and editor for Windows.",
  "main": "dist-electron/main.cjs",
  "author": "Iuzbi",
  "license": "MIT",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:icons": "node scripts/generate-icons.mjs",
    "dev": "npm run build:icons && concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-electron.mjs",
    "build": "npm run clean && npm run build:icons && npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder --win nsis",
    "start": "npm run build:icons && electron ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.2",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.iuzbi.mdread",
    "productName": "MoJian Markdown",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "icon": "build/file-association.ico"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "icon": "build/file-association.ico"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDist": "node_modules/electron/dist",
    "electronDownload": {
      "cache": ".electron-cache"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "sign": "./scripts/noop-sign.cjs",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/installer.ico",
      "installerHeaderIcon": "build/installer.ico",
      "include": "build/installer.nsh",
      "shortcutName": "MoJian Markdown"
    }
  }
}
